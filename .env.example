# Comma-separated API keys. Empty => API is open (dev only).
AEGIS_API_KEYS=demo-key
# Secret used to tokenize (HMAC) user identifiers before storage/logging.
AEGIS_PII_SECRET=change-me-in-prod
# SQLite by default; set a Postgres URL in production:
# AEGIS_DATABASE_URL=postgresql+psycopg://aegis:aegis@localhost:5432/aegis
AEGIS_LOG_LEVEL=INFO
# Proportional-response thresholds (0-100):
AEGIS_SCORE_STEP_UP=20
AEGIS_SCORE_REVIEW=45
AEGIS_SCORE_BLOCK=70
# Comma-separated CORS origins (empty => CORS disabled):
AEGIS_CORS_ORIGINS=
# Per-client requests/minute on /v1 (0 => disabled):
AEGIS_RATE_LIMIT_PER_MINUTE=0
